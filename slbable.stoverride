name: 负载均衡自动化
desc: 自动为所有节点创建散列和轮询负载均衡组
author: Gemini

# 1. 定义负载均衡策略组
proxy-groups:
  - name: ⚖️ 负载均衡-散列
    type: load-balance
    url: http://www.gstatic.com/generate_204
    interval: 180
    strategy: consistent-hashing
    udp: true
    # 方案 A：尝试使用更通用的匹配（匹配所有包含字母、数字或中文的名称）
    filter: ".+" 

  - name: ⚖️ 负载均衡-轮询
    type: load-balance
    url: http://www.gstatic.com/generate_204
    interval: 180
    strategy: round-robin
    udp: true
    filter: ".+"
