name: 负载均衡组配置（通用版）
desc: 自动包含所有节点，无需指定订阅标签

proxy-groups:
  # 散列负载均衡
  - name: ⚖️ 负载均衡-散列
    type: load-balance
    proxies: [__ALL__]   # ⚠️ Stash 特殊语法：代表所有代理节点
    strategy: consistent-hashing
    url: http://www.gstatic.com/generate_204
    interval: 300
  
  # 轮询负载均衡
  - name: ⚖️ 负载均衡-轮询
    type: load-balance
    proxies: [__ALL__]   # 同样代表所有节点
    strategy: round-robin
    url: http://www.gstatic.com/generate_204
    interval: 300
