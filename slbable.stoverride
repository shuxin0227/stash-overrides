name: ⚖️ 负载均衡自动分组
desc: 自动提取所有节点并创建散列与轮询负载均衡组
category: 策略组优化

proxy-groups:
  # ⚖️ 负载均衡 - 散列
  - name: ⚖️ 负载均衡-散列
    type: load-balance
    strategy: consistent-hashing
    use:
      - default
    filter: ".*"
    url: http://www.gstatic.com/generate_204
    interval: 150

  # ⚖️ 负载均衡 - 轮询
  - name: ⚖️ 负载均衡-轮询
    type: load-balance
    strategy: round-robin
    use:
      - default
    filter: ".*"
    url: http://www.gstatic.com/generate_204
    interval: 150